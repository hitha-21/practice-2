   "source": [
    "print(\"Truth Table for P AND Q\")\n",
    "print(\"P\\tQ\\tP AND Q\")\n",
    "\n",
    "values = [True, False]\n",
    "\n",
    "for P in values:\n",
    "   for Q in values:\n",
    "      result = P and Q\n",
    "print(P, \"\\t\", Q, \"\\t\", result)"
